{
  "$schema": "https://raw.githubusercontent.com/jjevsikov/CheckSpec/main/packages/core/checkspec.schema.json",
  "version": "1.0",
  "name": "Concurrent Test Examples",
  "description": "Demonstrates concurrency — run tests in parallel within each group",
  "server": {
    "command": "node",
    "args": [
      "demos/calculator-server/dist/index.js"
    ]
  },
  "concurrency": 3,
  "describe": [
    {
      "name": "addition (parallel)",
      "tests": [
        {
          "name": "add › positive numbers",
          "type": "tool-call",
          "tool": "add",
          "input": {
            "a": 3,
            "b": 4
          },
          "expect": {
            "success": true,
            "contains": "7"
          }
        },
        {
          "name": "add › negative numbers",
          "type": "tool-call",
          "tool": "add",
          "input": {
            "a": -5,
            "b": -3
          },
          "expect": {
            "success": true,
            "contains": "-8"
          }
        },
        {
          "name": "add › zero identity",
          "type": "tool-call",
          "tool": "add",
          "input": {
            "a": 42,
            "b": 0
          },
          "expect": {
            "success": true,
            "contains": "42"
          }
        }
      ]
    },
    {
      "name": "multiplication (parallel)",
      "tests": [
        {
          "name": "multiply › basic",
          "type": "tool-call",
          "tool": "multiply",
          "input": {
            "a": 6,
            "b": 7
          },
          "expect": {
            "success": true,
            "contains": "42"
          }
        },
        {
          "name": "multiply › by zero",
          "type": "tool-call",
          "tool": "multiply",
          "input": {
            "a": 99,
            "b": 0
          },
          "expect": {
            "success": true,
            "contains": "0"
          }
        }
      ]
    }
  ],
  "tests": [
    {
      "name": "divide › basic division",
      "type": "tool-call",
      "tool": "divide",
      "input": {
        "a": 10,
        "b": 2
      },
      "expect": {
        "success": true,
        "contains": "5"
      }
    },
    {
      "name": "divide › divide by zero returns error",
      "type": "tool-call",
      "tool": "divide",
      "input": {
        "a": 9,
        "b": 0
      },
      "expect": {
        "success": false,
        "contains": "zero"
      }
    }
  ]
}
