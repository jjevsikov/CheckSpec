{
  "$schema": "https://raw.githubusercontent.com/jjevsikov/CheckSpec/main/packages/core/checkspec.schema.json",
  "version": "1.0",
  "name": "streaming-server — Streaming Assertions Demo",
  "description": "Demonstrates streaming-tool-call tests with progress notification assertions. Shows minChunks, chunkContains, maxChunkIntervalMs, finalContains, and maxTotalMs assertions.",
  "server": {
    "command": "node",
    "args": [
      "demos/streaming-server/dist/index.js"
    ]
  },
  "tests": [
    {
      "id": "countdown-basic",
      "name": "stream_countdown › counts from 5 to 0",
      "type": "streaming-tool-call",
      "tool": "stream_countdown",
      "input": {
        "from": 5
      },
      "streamExpect": {
        "minChunks": 5,
        "finalContains": "done",
        "maxTotalMs": 3000
      },
      "tags": [
        "streaming",
        "countdown"
      ]
    },
    {
      "id": "countdown-chunk-timing",
      "name": "stream_countdown › chunks arrive within 500ms of each other",
      "type": "streaming-tool-call",
      "tool": "stream_countdown",
      "input": {
        "from": 4
      },
      "streamExpect": {
        "minChunks": 4,
        "maxChunkIntervalMs": 500,
        "maxTotalMs": 3000
      },
      "tags": [
        "streaming",
        "countdown",
        "backpressure"
      ]
    },
    {
      "id": "text-chunks-basic",
      "name": "stream_text_chunks › assembles final result from chunks",
      "type": "streaming-tool-call",
      "tool": "stream_text_chunks",
      "input": {
        "text": "hello world",
        "chunkSize": 4
      },
      "streamExpect": {
        "minChunks": 3,
        "finalContains": "hello world",
        "maxTotalMs": 2000
      },
      "tags": [
        "streaming",
        "text-chunks"
      ]
    },
    {
      "id": "text-chunks-chunk-content",
      "name": "stream_text_chunks › every chunk contains expected fragment",
      "type": "streaming-tool-call",
      "tool": "stream_text_chunks",
      "input": {
        "text": "abcabcabc",
        "chunkSize": 3
      },
      "streamExpect": {
        "minChunks": 3,
        "chunkContains": "abc",
        "finalContains": "abcabcabc",
        "maxTotalMs": 2000
      },
      "tags": [
        "streaming",
        "text-chunks"
      ]
    },
    {
      "id": "slow-query-basic",
      "name": "stream_slow_query › fetches 3 rows with progress notifications",
      "type": "streaming-tool-call",
      "tool": "stream_slow_query",
      "input": {
        "rows": 3
      },
      "streamExpect": {
        "minChunks": 3,
        "finalContains": "record_1",
        "maxTotalMs": 3000
      },
      "tags": [
        "streaming",
        "slow-query"
      ]
    },
    {
      "id": "slow-query-progress-content",
      "name": "stream_slow_query › progress messages mention 'fetching row'",
      "type": "streaming-tool-call",
      "tool": "stream_slow_query",
      "input": {
        "rows": 2
      },
      "streamExpect": {
        "minChunks": 2,
        "chunkContains": "fetching row",
        "maxTotalMs": 2000
      },
      "tags": [
        "streaming",
        "slow-query"
      ]
    },
    {
      "id": "slow-query-interval",
      "name": "stream_slow_query › row fetches arrive within 600ms of each other",
      "type": "streaming-tool-call",
      "tool": "stream_slow_query",
      "input": {
        "rows": 3
      },
      "streamExpect": {
        "minChunks": 3,
        "maxChunkIntervalMs": 600,
        "maxTotalMs": 3000
      },
      "tags": [
        "streaming",
        "slow-query",
        "backpressure"
      ]
    },
    {
      "id": "countdown-deliberate-fail",
      "name": "stream_countdown › deliberately failing — teardown still runs after this",
      "type": "streaming-tool-call",
      "tool": "stream_countdown",
      "input": {
        "from": 5
      },
      "streamExpect": {
        "minChunks": 999
      },
      "tags": [
        "streaming",
        "expected-failure"
      ]
    }
  ]
}
