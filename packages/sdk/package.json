{
  "name": "@checkspec/sdk",
  "version": "0.2.0",
  "type": "module",
  "description": "Programmatic SDK for embedding CheckSpec in test frameworks, CI scripts, and other tools",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testing",
    "sdk",
    "llm"
  ],
  "homepage": "https://github.com/jjevsikov/CheckSpec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jjevsikov/CheckSpec.git"
  },
  "author": "jjevsikov",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jjevsikov/CheckSpec/issues"
  },
  "files": [
