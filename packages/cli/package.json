{
  "name": "@checkspec/cli",
  "version": "0.2.0",
  "type": "module",
  "description": "CLI tool for testing MCP servers — protocol conformance, schema-driven fuzzing, and security scanning",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "testing",
    "security",
    "llm",
    "ai"
  ],
  "homepage": "https://github.com/jjevsikov/CheckSpec",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jjevsikov/CheckSpec.git"
  },
  "bugs": {
    "url": "https://github.com/jjevsikov/CheckSpec/issues"
  },
  "author": "jjevsikov",
  "license": "MIT",
  "bin": {
